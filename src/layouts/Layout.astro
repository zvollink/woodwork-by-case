---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Custom woodwork, built-ins, furniture, and playsets by Case Vollink — serving the DFW Metroplex." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --forest:   #2C5F2D;
    --forest-dk:#1e4220;
    --oak:      #C19A6B;
    --oak-lt:   #d4b48c;
    --cream:    #FAF8F3;
    --white:    #ffffff;
    --ink:      #1C1C1A;
    --muted:    #6B6860;
    --border:   rgba(193,154,107,0.22);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif;
    line-height: 1.65;
    color: var(--ink);
    background: var(--cream);
  }

  h1, h2, h3 {
    font-family: 'Playfair Display', Georgia, serif;
    line-height: 1.2;
  }
</style>
