---
---

<header>
  <nav>
    <a href="#hero" class="logo">
      <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M4 24 L14 4 L24 24" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <path d="M8 17 L20 17" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
      <span>Woodwork by Case</span>
    </a>
    <div class="links">
      <a href="#about">About</a>
      <a href="#projects">Work</a>
      <a href="#contact" class="cta">Get a Quote</a>
    </div>
    <button class="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<script>
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const links = document.querySelector('.links') as HTMLElement;
  btn.addEventListener('click', () => {
    const open = links.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(open));
  });
  // close on nav link click
  links.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      links.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    });
  });
</script>

<style>
  header {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2.5rem;
    background: rgba(250, 248, 243, 0.96);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.3s;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--forest);
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .logo svg {
    flex-shrink: 0;
  }

  .links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .links a {
    text-decoration: none;
    color: var(--ink);
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    transition: color 0.2s;
    position: relative;
  }

  .links a:not(.cta)::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    right: 100%;
    height: 1.5px;
    background: var(--oak);
    transition: right 0.25s ease;
  }

  .links a:not(.cta):hover {
    color: var(--forest);
  }

  .links a:not(.cta):hover::after {
    right: 0;
  }

  .cta {
    background: var(--forest);
    color: var(--white) !important;
    padding: 0.55rem 1.25rem;
    border-radius: 6px;
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    transition: background 0.2s !important;
  }

  .cta:hover {
    background: var(--forest-dk) !important;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 640px) {
    nav {
      padding: 1rem 1.25rem;
    }

    .hamburger {
      display: flex;
    }

    .links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--cream);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      border-bottom: 1px solid var(--border);
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }

    .links.open {
      display: flex;
    }

    .links a {
      width: 100%;
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--border);
      font-size: 1rem !important;
    }

    .cta {
      border-radius: 0 !important;
      padding: 1rem 1.25rem !important;
      background: var(--forest) !important;
    }
  }
</style>
