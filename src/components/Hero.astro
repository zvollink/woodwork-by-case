---
---

<section id="hero">
  <div class="bg">
    <img src="/king-canopy-rustic-bedframe.jpg" alt="Rustic king canopy bed frame hand-crafted by Case Vollink" />
    <div class="overlay"></div>
  </div>
  <div class="content">
    <p class="eyebrow">DFW Metroplex &amp; Beyond</p>
    <h1>Built by hand.<br />Built to last.</h1>
    <p class="sub">
      Custom woodwork, built-ins, furniture, and playsets — crafted with care by Case Vollink out of his workshop in Texas.
    </p>
    <div class="actions">
      <a href="#contact" class="btn-primary">Start Your Project</a>
      <a href="#projects" class="btn-ghost">See the Work</a>
    </div>
  </div>
  <a href="#about" class="scroll-hint" aria-label="Scroll down">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 7 L10 13 L16 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</section>

<style>
  section {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15, 25, 15, 0.55) 0%,
      rgba(15, 25, 15, 0.45) 60%,
      rgba(15, 25, 15, 0.75) 100%
    );
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 6rem 1.5rem 4rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--oak-lt);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    color: var(--white);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
    text-shadow: 0 2px 20px rgba(0,0,0,0.3);
  }

  .sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: rgba(255,255,255,0.82);
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--oak);
    color: var(--white);
    text-decoration: none;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }

  .btn-primary:hover {
    background: var(--oak-lt);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    text-decoration: none;
    padding: 0.85rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    border: 1.5px solid rgba(255,255,255,0.5);
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
  }

  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.1);
    transform: translateY(-1px);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: rgba(255,255,255,0.55);
    animation: bounce 2.2s ease-in-out infinite;
    transition: color 0.2s;
  }

  .scroll-hint:hover {
    color: rgba(255,255,255,0.9);
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }
</style>
